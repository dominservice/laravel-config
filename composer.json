{
  "name": "dominservice/laravel-config",
  "description": "Merge default config with dynamic settings, and optimize.",
  "type": "library",
  "keywords": ["laravel", "config"],
  "homepage": "https://github.com/dominservice/laravel-config",
  "license": "MIT",
  "authors": [
    {
      "name": "DSO-IT Mateusz Domin",
      "email": "biuro@dso.biz.pl"
    }
  ],
  "require": {
    "php": "^8.1",
    "ext-json": "*",
    "laravel/framework": "^10.0|^11.0|^12.0|^13.0"
  },
  "require-dev": {
    "orchestra/testbench": "^8.0|^9.0|^10.0|^11.0",
    "phpunit/phpunit": "^10.5|^11.5|^12.0"
  },
  "autoload": {
    "files": [
      "src/Helpers/helpers.php"
    ],
    "psr-4": {
      "Dominservice\\LaravelConfig\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Dominservice\\LaravelConfig\\Tests\\": "tests/"
    }
  },
  "extra": {
    "laravel": {
      "providers": [
        "Dominservice\\LaravelConfig\\ServiceProvider"
      ]
    }
  },
  "config": {
    "sort-packages": true
  },
  "scripts": {
    "post-autoload-dump": [
      "@php vendor/bin/testbench package:discover --ansi"
    ],
    "test": [
      "@php vendor/bin/phpunit --colors=always"
    ]
  },
  "minimum-stability": "stable",
  "prefer-stable": true
}
